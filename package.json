    "test:workflow": "node scripts/workflow-runtime-smoke.mjs",
    "test:store-diagnosis": "node scripts/ozon-store-diagnosis-parity-smoke.mjs",
    "test:etsy-parity": "node scripts/etsy-parity-upgrade-smoke.mjs",
    "test:sourcing": "node scripts/sourcing-workflow-guard-smoke.mjs",
